{
  "symbol": "WTI",
  "commodity": "crude_oil",
  "entry_threshold_long": 0.2,
  "entry_threshold_short": -0.2,
  "strong_entry_threshold_long": 0.6,
  "strong_entry_threshold_short": -0.6,
  "base_position": 1.0,
  "strong_position": 2.0,
  "max_abs_position": 2.0,
  "hold_if_same_sign": true,
  "flat_if_neutral": true,
  "one_way_cost_bps": 5.0,
  "initial_capital": 100000.0,
  "scoring": {
    "use_themes": true,
    "theme_weights": {
      "supply": 1.0,
      "demand": 1.0,
      "inventories": 0.8,
      "macro": 0.6,
      "geopolitics": 1.2,
      "other": 0.5
    },
    "theme_vetoes": [
      {
        "if_theme": "macro",
        "is": "below",
        "value": -1.0,
        "blocks": "long",
        "note": "Don't go long oil when macro is strongly bearish (recession / dollar-strength regime)."
      },
      {
        "if_theme": "macro",
        "is": "above",
        "value": 1.0,
        "blocks": "short",
        "note": "Don't go short when macro is strongly bullish."
      }
    ]
  },
  "regime_factor_weights": {
    "_comment": "Per-regime weights for composite_score(). Factors named here must be supplied in the `factors` dict and/or as `narrative_score`. Weights are starting priors — refit by backtest. Keys must match primary_regime labels from app/research/regime.py.",
    "trend_up":       {"narrative": 0.20, "term_structure": 0.25, "momentum": 0.30, "positioning": 0.10, "inventory": 0.15},
    "trend_down":     {"narrative": 0.20, "term_structure": 0.25, "momentum": 0.30, "positioning": 0.10, "inventory": 0.15},
    "range":          {"narrative": 0.25, "term_structure": 0.15, "mean_reversion": 0.30, "positioning": 0.10, "inventory": 0.20},
    "stretched_up":   {"narrative": 0.15, "term_structure": 0.15, "mean_reversion": 0.25, "positioning": 0.25, "inventory": 0.20},
    "stretched_down": {"narrative": 0.15, "term_structure": 0.15, "mean_reversion": 0.25, "positioning": 0.25, "inventory": 0.20},
    "shock":          {"narrative": 0.35, "inventory": 0.30, "term_structure": 0.20, "positioning": 0.15}
  }
}
