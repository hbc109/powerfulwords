      "params": {
        "subreddit": "oil",
        "source_id": "reddit_oil",
        "source_bucket": "social_open",
        "listing": "new",
        "limit": 15
      }
    },
    {
      "name": "reddit_oilandgasworkers",
      "type": "reddit",
      "enabled": true,
      "params": {
        "subreddit": "oilandgasworkers",
        "source_id": "reddit_oil",
        "source_bucket": "social_open",
        "listing": "new",
        "limit": 10
      }
    },
    {
      "name": "eia_twip",
      "type": "rss",
      "enabled": true,
      "params": {
        "feed_url": "https://www.eia.gov/petroleum/weekly/rss.xml",
        "source_id": "eia_steo",
        "source_bucket": "official_reports",
        "limit": 10,
        "follow_links": true
