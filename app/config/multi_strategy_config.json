          "macro": 0.6,
          "geopolitics": 1.2,
          "other": 0.5
        },
        "theme_vetoes": [
          {"if_theme": "macro", "is": "below", "value": -1.0, "blocks": "long",
           "note": "Don't long oil while macro is strongly bearish (recession / dollar-strength)."},
          {"if_theme": "macro", "is": "above", "value": 1.0, "blocks": "short",
           "note": "Don't short oil while macro is strongly bullish."},
          {"if_theme": "geopolitics", "is": "above", "value": 1.5, "blocks": "short",
           "note": "Don't short into a strong geopolitical risk-on tape."},
          {"if_theme": "geopolitics", "is": "below", "value": -1.5, "blocks": "long",
           "note": "Don't long into geopolitical risk-off (e.g. ceasefire, sanctions lifted)."}
        ]
      }
    },
