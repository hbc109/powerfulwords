# Streamlit Community Cloud secrets for powerfulwords.
# Copy these keys into the app's Settings -> Secrets box on share.streamlit.io.
# (This .example file is committed; the real secrets.toml is gitignored.)

# Neon Postgres POOLED connection string (the app should use the pooler endpoint).
DATABASE_URL = "postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/dbname?sslmode=require"

# Claude (narrative extraction / AI review). Claude-only per project preference.
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: EIA inventory / futures fetches. Leave unset to skip those panels.
EIA_API_KEY = ""
