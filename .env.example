# Pick whichever provider matches app/config/llm_config.json -> "provider".
# Default is now deepseek, so set DEEPSEEK_API_KEY (OpenAI-compatible).
# ANTHROPIC_API_KEY / OPENAI_API_KEY are only needed if you switch the
# provider field back to "anthropic" / "openai".
DEEPSEEK_API_KEY=your_deepseek_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
