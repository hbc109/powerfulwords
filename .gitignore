# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime data
data/oil_narrative.db
data/processed/events/*
data/processed/signals/*
data/processed/research/*
data/processed/backtests/*
data/processed/clean_text/*
data/processed/metadata/*
data/processed/chunks/*

# Keep directories
!data/processed/events/.gitkeep
!data/processed/signals/.gitkeep
!data/processed/research/.gitkeep
!data/processed/backtests/.gitkeep
!data/processed/clean_text/.gitkeep
!data/processed/metadata/.gitkeep
!data/processed/chunks/.gitkeep

# Inbox: never commit fetched/dropped content (it's user data, can be huge,
# and may be third-party content we don't have the right to redistribute).
# Only the folder skeleton (.gitkeep) and the demo seeds checked in
# explicitly are tracked.
data/inbox/**
!data/inbox/README.md
!data/inbox/**/.gitkeep
!data/inbox/official_reports/opec_momr/2026-04-19_opec_supply_note.txt
!data/inbox/social_private_manual/telegram_forwarded/2026-04-19_redsea_tanker_note.txt

# Themes: discovery proposals are runtime artefacts
data/processed/themes/*
!data/processed/themes/.gitkeep

# Digests: morning output, regenerated each run
data/processed/digests/*
!data/processed/digests/.gitkeep

# Environment
.env
.env.local
